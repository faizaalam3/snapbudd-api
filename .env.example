# Server
PORT=3000
NODE_ENV=development

# Firebase Admin (project: snapbudd-1)
FIREBASE_PROJECT_ID=snapbudd-1
# Local dev: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/snapbudd-1-service-account.json
# Cloud (Render/Railway): paste entire service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Stripe (same secret as Snapbudd Cloud Functions)
STRIPE_SECRET_KEY=sk_live_or_test_...

# Platform fees (match Snapbudd functions defaults)
PLATFORM_FIXED_FEE_NOK=29
PLATFORM_PERCENT_FEE=0.1

# Google Maps (geocoding for order creation)
GOOGLE_MAPS_API_KEY=AIzaSyCyKUAlNx5XiqngGwM7Gclkrm6LCPOLzVk

# Public URLs
API_BASE_URL=https://snapbudd-api.onrender.com
MERCHANT_TRACKING_BASE_URL=https://snapbudd.io/track

# CORS (comma-separated origins for merchant websites)
CORS_ORIGINS=*
 